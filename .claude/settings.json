{
  "permissions": {
    "allow": [
      "Bash(docker compose:*)",
      "Bash(docker ps:*)",
      "Bash(docker cp:*)",
      "Bash(docker info:*)",
      "Bash(curl:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sed:*)",
      "Bash(sleep:*)",
      "Bash(echo:*)",
      "Bash(bash:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(netstat:*)",
      "Bash(ipconfig:*)",
      "Bash(ngrok:*)",
      "Bash(cloudflared:*)",
      "Bash(pip:*)",
      "Bash(mkdir:*)",
      "Bash(rm:*)",
      "Bash(cd:*)",
      "Bash(sort:*)",
      "Bash(xargs:*)",
      "Bash(while:*)",
      "Bash(for:*)",
      "mcp__Claude_Preview__preview_start",
      "mcp__Claude_Preview__preview_screenshot",
      "mcp__Claude_Preview__preview_snapshot",
      "mcp__Claude_Preview__preview_eval",
      "mcp__Claude_Preview__preview_click",
      "mcp__Claude_Preview__preview_fill",
      "mcp__Claude_Preview__preview_inspect",
      "mcp__Claude_Preview__preview_console_logs",
      "mcp__Claude_Preview__preview_network",
      "mcp__Claude_Preview__preview_logs",
      "mcp__Claude_Preview__preview_stop",
      "mcp__Claude_Preview__preview_resize",
      "WebFetch",
      "WebSearch"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import sys,json;d=json.load(sys.stdin);f=d.get('tool_input',{}).get('file_path',d.get('tool_response',{}).get('filePath',''));menu_files=['router/index.ts','PortalLayout.vue','AdminLayout.vue','SiteMap.vue','CLAUDE.md'];m=[mf for mf in menu_files if mf in f];msg='Menu file modified: '+f+'. Sync router/index.ts, PortalLayout.vue, SiteMap.vue, CLAUDE.md' if m else '';print(json.dumps({'systemMessage':msg} if msg else {}))\" 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Checking file change..."
          }
        ]
      }
    ]
  }
}
