# ───────────────────────────────────────────────────────────
# K-water DataHub Portal - 환경변수 템플릿
#   복사: cp .env.example .env
#   실제 .env 파일은 커밋하지 마세요 (.gitignore 필수)
# ───────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql+asyncpg://datahub:datahub@postgres:5432/datahub
DATABASE_URL_SYNC=postgresql+psycopg://datahub:datahub@postgres:5432/datahub

# Redis
REDIS_URL=redis://redis:6379/0

# JWT (필수: 16자 이상. openssl rand -hex 32 권장)
JWT_SECRET_KEY=change-me-to-a-random-secret-at-least-16-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (개발만 "*" 허용, 운영은 도메인 명시)
CORS_ORIGINS=["*"]

# Object Storage (MinIO / S3)
OBJECT_STORAGE_ENDPOINT=minio:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=datahub
OBJECT_STORAGE_SECURE=false
OBJECT_STORAGE_REGION=us-east-1

# 유통 API 엔드포인트 (API 키 발급 시 사용자에게 제공)
DISTRIBUTION_API_ENDPOINT=https://api.kwater.or.kr/data/v1/query

# SAML 2.0 (오아시스 SSO)
SAML_SP_ENTITY_ID=https://datahub.kwater.or.kr
SAML_SP_ACS_URL=https://datahub.kwater.or.kr/api/v1/sso/saml/acs
SAML_IDP_ENTITY_ID=https://oasis.kwater.or.kr/idp
SAML_IDP_SSO_URL=https://oasis.kwater.or.kr/idp/sso

# ERP 연계
ERP_API_URL=https://erp.kwater.or.kr/api/hr
ERP_API_KEY=

# OpenMetadata (선택)
OPENMETADATA_URL=http://openmetadata:8585/api
OPENMETADATA_JWT_TOKEN=

# Workers
WEB_CONCURRENCY=4
